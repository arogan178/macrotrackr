{
  "name": "macrotrackr-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vite build",
    "postbuild": "bun ./scripts/generate-sitemap.js || node ./scripts/generate-sitemap.js",
    "preview": "bunx vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:e2e": "playwright test --config ./playwright.config.ts",
    "test:e2e:ui": "playwright test --config ./playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config ./playwright.config.ts --debug",
    "test:e2e:headed": "playwright test --config ./playwright.config.ts --headed",
    "build:analyze": "bunx vite build --mode analyze",
    "bundle:size": "node scripts/analyze-bundle.js"
  },
  "dependencies": {
