# Frontend environment template (Self-hosted defaults)

# --- Core App Config ---
# Leave empty to use same-origin `/api` (recommended for Docker Compose)
VITE_API_URL=
VITE_APP_URL=http://localhost:5173
VITE_PUBLIC_APP_NAME=Macro Tracker
VITE_SUPPORT_EMAIL=support@local.invalid

# --- Public Links (Optional) ---
VITE_GITHUB_REPO_URL=https://github.com/arogan178/macro_tracker
VITE_DOCS_URL=https://github.com/arogan178/macro_tracker/tree/main/docs

# --- Runtime Profiles ---
VITE_AUTH_MODE=local
VITE_BILLING_MODE=disabled
VITE_ANALYTICS_MODE=disabled
