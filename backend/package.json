{
  "name": "macro-tracker-backend",
  "version": "1.0.0",
  "description": "Backend API for Macro Trackr application",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "dotenvx run --env-file .env.production -- bun run src/index.ts",
    "dev": "dotenvx run --env-file .env.development -- bun --watch src/index.ts",
    "migrate:clerk:dev": "dotenvx run --env-file .env.development -- bun run scripts/migrate-dev-users-to-clerk.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "elysia",
    "bun",
    "macros",
    "tracker",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/bun": "latest",
    "@types/compression": "^1.8.1",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.3",
    "globals": "^15.15.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.53.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/swagger": "latest",
    "@node-rs/bcrypt": "^1.10.7",
    "svix": "^1.65.0",
    "@types/stripe": "^8.0.417",
    "compression": "^1.8.1",
    "elysia": "^1.4.27",
    "elysia-clerk": "^0.13.2",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "resend": "^4.8.0",
    "stripe": "^18.5.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  }
}
