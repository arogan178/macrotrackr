{
  "name": "macro-tracker",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "bun run --cwd backend dev & bun run --cwd frontend dev",
    "dev:backend": "bun run --cwd backend dev",
    "dev:frontend": "bun run --cwd frontend dev",
    "build": "bun run --cwd frontend build",
    "build:backend": "bun run --cwd backend build",
    "start": "bun run --cwd backend start",
    "test": "bun run --cwd frontend test",
    "lint": "bun run --cwd frontend lint",
    "typecheck": "bun run --cwd backend typecheck & bun run --cwd frontend typecheck"
  },
  "devDependencies": {
    "@types/react-syntax-highlighter": "^15.5.13",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
